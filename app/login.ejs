<div id="loginContainer" style="display: none;">
    <div id="loginCancelContainer" style="display: none;">
        <button id="loginCancelButton" onclick="loginCancelEnabled(false)">
            <div id="loginCancelIcon">&#x2715;</div>
            <span id="loginCancelText"><%- lang('login.loginCancelText') %></span>
        </button>
    </div>

    <div id="loginContent">
        <img id="loginImageSeal" src="assets/images/SealCircle.png"/>
        <span id="loginSubheader"><%- lang('login.loginSubheader') %></span>

        <!-- Botón Microsoft -->
        <button id="loginMicrosoftButton" onclick="loginWithMicrosoft()">
            Iniciar Sesión con Microsoft
        </button>

        <div id="loginDivider">
            <span>o</span>
        </div>

        <!-- Modo offline / no-premium -->
        <div id="loginOfflineForm">
            <div id="loginOfflineUsernameField">
                <input id="loginOfflineUsername"
                       type="text"
                       maxlength="16"
                       placeholder="Nombre de usuario (offline)"
                       autocomplete="off"/>
                <span id="loginOfflineUsernameError" class="loginError"></span>
            </div>
            <button id="loginOfflineButton" disabled onclick="loginOffline()">
                Entrar sin cuenta
            </button>
        </div>

        <span id="loginOfflineDisclaimer">
            Requiere estar en la whitelist del servidor.
        </span>
    </div>

    <script src="assets/js/scripts/login.js"></script>
</div>
